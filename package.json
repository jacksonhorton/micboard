{
	"name": "micboard",
	"description": "Build a personal website, blog, or portfolio with Astro.",
	"cloudflare": {
		"label": "Astro Framework Starter",
		"products": [
			"Workers"
		],
		"categories": [],
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/394ca3c9-d351-4036-035a-9f6dfa26dd00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/f40a6577-eed5-4f3e-cef4-b5ef0a1be100/preview",
		"publish": true
	},
	"dependencies": {
		"@astrojs/cloudflare": "^12.5.4",
		"@astrojs/mdx": "^4.3.0",
		"@astrojs/rss": "4.0.17",
		"@astrojs/sitemap": "3.7.1",
		"@astrojs/tailwind": "^6.0.2",
		"astro": "^5.11.1",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"jose": "^6.2.1",
		"svelte": "^5.54.0",
		"tailwindcss": "^3.4.19",
		"typescript": "5.9.3"
	},
	"devDependencies": {
		"@astrojs/svelte": "^7.1.0",
		"@cloudflare/workers-types": "^4.20250610.0",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@types/form-data": "^2.5.2",
		"@types/jsonwebtoken": "^9.0.9",
		"bits-ui": "2.16.3",
		"chokidar-cli": "^3.0.0",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.2.2",
		"wrangler": "4"
	},
	"engines": {
		"node": ">=22"
	},
	"private": true,
	"scripts": {
		"build": "ENV=pprd astro build",
		"preview": "ENV=pprd astro build && wrangler dev -e dev --live-reload --local --persist-to worker-local",
		"astro": "astro",
		"deploy": "ENV=prod astro build && wrangler deploy --env=\"\"",
		"cf-typegen": "wrangler types",
		"watch": "wrangler tail ivys",
		"test:build": "chokidar \"src/**/*.{astro,ts,svelte,css}\" -c \"ENV=pprd astro build\"",
		"watch:build": "ENV=pprd astro build",
		"dev:wrangler": "wrangler dev --live-reload --local --persist-to worker-local",
		"dev": "wrangler dev --live-reload --local --persist-to worker-local --ip 0.0.0.0"
	},
	"type": "module"
}
