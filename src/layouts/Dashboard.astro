---
import BaseHead from "$lib/components/BaseHead.astro";
import Footer from "$lib/components/Footer.astro";
import AppSidebar from "$lib/components/AppSidebar.svelte";

type SidebarProject = {
	id: string;
	name: string;
};

interface Props {
	title?: string;
	description?: string;
	projects?: SidebarProject[];
	defaultProjectId?: string;
}

const {
	title = "Dashboard",
	description = "Dashboard",
	projects,
	defaultProjectId,
}: Props = Astro.props;
const userName = Astro.locals.auth?.name ?? "User";
const email = Astro.locals.auth?.email ?? "Email";

---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script is:inline>
			(() => {
				const key = "dashboard-theme";
				const root = document.documentElement;
				const stored = localStorage.getItem(key);
				root.classList.toggle("dashboard-dark", stored === "dark");
			})();
		</script>
	</head>

	<body>
		<div class="dashboard-shell">
			<AppSidebar
				userName={userName}
				email={email}
				{projects}
				{defaultProjectId}
				client:load
			/>
			<main>
				<slot />
			</main>
		</div>
	</body>
</html>

<style>
	.dashboard-shell {
		display: flex;
		min-height: 70vh;
		align-items: stretch;
	}

	.dashboard-shell :global([data-slot="sidebar-wrapper"]) {
		flex: 0 0 auto;
		width: auto;
	}

	.dashboard-shell > main {
		flex: 1 1 auto;
		width: auto;
		max-width: none;
		margin: 0;
		padding: 2rem;
		background: hsl(var(--background));
		color: hsl(var(--foreground));
	}

	:global(html.dashboard-dark) {
		--background: 96 10% 11%;
		--foreground: 90 18% 92%;
		--card: 95 9% 15%;
		--card-foreground: 90 18% 92%;
		--popover: 95 9% 15%;
		--popover-foreground: 90 18% 92%;
		--muted: 95 8% 19%;
		--muted-foreground: 95 8% 68%;
		--border: 95 8% 24%;
		--input: 95 8% 24%;
		--accent: 95 9% 24%;
		--accent-foreground: 90 18% 92%;
		--primary: 91 23% 64%;
		--primary-foreground: 96 14% 12%;
		--secondary: 80 3% 62%;
		--secondary-foreground: 96 14% 12%;
		--ring: 91 23% 64%;
		--sidebar-background: 95 12% 13%;
		--sidebar-foreground: 90 18% 92%;
		--sidebar-primary: 91 23% 64%;
		--sidebar-primary-foreground: 96 14% 12%;
		--sidebar-accent: 95 9% 22%;
		--sidebar-accent-foreground: 90 18% 92%;
		--sidebar-border: 95 8% 24%;
		--sidebar-ring: 91 23% 64%;
	}
</style>
