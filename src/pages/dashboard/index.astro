---
import DashboardLayout from "$lib/layouts/Dashboard.astro";

const auth = Astro.locals.auth;
const displayName = auth?.name ?? "User";
const displayEmail = auth?.email ?? "No email found";
---

<DashboardLayout>
	<h1>Dashboard</h1>
	<section class="card">
		<p><strong>Name:</strong> {displayName}</p>
		<p><strong>Email:</strong> {displayEmail}</p>
		<form method="post" action="/api/auth/logout?returnTo=/auth">
			<button type="submit">Logout</button>
		</form>
	</section>
</DashboardLayout>

