<style>
	.card {
		border: 1px solid hsl(var(--border));
		border-radius: 12px;
		padding: 1.25rem;
		background: hsl(var(--card));
		color: hsl(var(--card-foreground));
		box-shadow: 0 8px 24px hsl(var(--foreground) / 0.08);
	}

	button {
		margin-top: 0.5rem;
		border: 1px solid hsl(var(--border));
		border-radius: 8px;
		padding: 0.55rem 0.85rem;
		cursor: pointer;
		background: hsl(var(--card));
		color: hsl(var(--card-foreground));
	}
</style>
